{
	"name": "n8n-nodes-habsync",
	"version": "1.0.5-6",
	"description": "Habsync integration nodes for n8n - enabling ERP automation, inventory intelligence, and external service workflows.",
	"license": "MIT",
	"homepage": "",
	"private": false,
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"erp",
		"automation",
		"habsync"
	],
	"author": {
		"name": "Habsync Platform",
		"email": "dev@habsync.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/habsync-erp/n8n-nodes-hs-core.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/HabSyncApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/HabSync/HabSync.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
